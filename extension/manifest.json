{
  "manifest_version": 3,
  "name": "아고다 가격 비교기",
  "version": "0.1.1",
  "description": "아고다 숙소를 로케일별로 자동 접속해 가격을 수집·비교합니다.",
  "permissions": ["tabs", "scripting", "storage", "cookies"],
  "host_permissions": [
    "*://*.agoda.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "아고다 가격 비교기"
  }
}
